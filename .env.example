# ── Server ───────────────────────────────────────────────
PORT=3000
PUBLIC_BASE_URL=https://your-ngrok-or-domain.example.com

# ── Anthropic (Claude) ───────────────────────────────────
# Leave blank to run the agent in deterministic rule-based fallback mode.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# ── Twilio ───────────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=

# ── Email (SMTP / Nodemailer) ────────────────────────────
# Leave blank to log emails to the console instead of sending.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=bookings@yourdomain.com

# ── Google Calendar (OAuth 2.0) ──────────────────────────
# Leave blank to run with an in-memory mock calendar (great for demos).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/oauth2/callback
GOOGLE_REFRESH_TOKEN=
